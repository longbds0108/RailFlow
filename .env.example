# ArcFlow environment template — copy to .env and fill in.
# Stack: Next.js + wagmi/viem + Hardhat + Node backend/indexer.

# --- Arc Testnet network (§1) ---
ARC_CHAIN_ID=
ARC_RPC_URL=
ARC_EXPLORER_URL=
ARC_NETWORK_NAME=
ARC_NATIVE_SYMBOL=
ARC_NATIVE_DECIMALS=

# --- Tokens (§2) ---
USDC_ADDRESS=
USDC_DECIMALS=
EURC_ADDRESS=
EURC_DECIMALS=
CIRBTC_ADDRESS=
CIRBTC_DECIMALS=

# --- Wallets & keys (§3) --- (dedicated testnet wallet only)
DEPLOYER_PRIVATE_KEY=
PAYMENT_RECEIVER_ADDRESS=
ADMIN_ADDRESSES=

# --- Payment (§4) ---
ORDER_TIMEOUT_MINUTES=

# --- Swap (§5) ---
SWAP_FEE_BPS=
DEFAULT_SLIPPAGE_BPS=
DEX_ROUTER_ADDRESS=

# --- Staking (§6) ---
STAKING_LOCK_SECONDS=
STAKING_MIN_AMOUNT=

# --- Bridge / CCTP (§7) ---
CCTP_ENABLED=true
CCTP_IRIS_API_URL=
# per-network values go in config/bridge.json (TokenMessenger, MessageTransmitter, domain id)

# --- Backend / DB (§8) ---
DATABASE_URL=
INDEXER_MODE=poll

# --- Admin (§9) ---
ADMIN_AUTH_MODE=siwe

# --- Frontend public (exposed to browser) ---
NEXT_PUBLIC_ARC_CHAIN_ID=
NEXT_PUBLIC_ARC_RPC_URL=
NEXT_PUBLIC_APP_NAME=ArcFlow
